			"problemMatcher": [],
			"presentation": {
				"reveal": "always"
			},
			"group": "build"
		},
		{
			"label": "Print Setting Value",
			"type": "shell",
			// "command": "echo 'The value of editor.fontSize is: ${config:editor.fontSize}'",
			"command": "echo",
			"args": [
				"The value of C_Cpp.clang_format_path is: ${config:C_Cpp.clang_format_path}"
			],
			"problemMatcher": []
		},
                {
                        "label": "make",
                        "type": "shell",
                        "command": "/usr/bin/make",
                        "args": [
                                "-j8"
                        ],
                        "group": {
                                "kind": "build",
                                "isDefault": true
                        },
                        "problemMatcher": [
                                "$gcc"
                        ]
                },
                {
                        "label": "make clean",
                        "type": "shell",
                        "command": "/usr/bin/make",
                        "args": [
                                "clean"
                        ],
                        "group": "none"
                }
        ]
}